#!/usr/bin/env python3
"""logbook — install logbook recorder.

Records executed shell commands, prose notes and section markers to JSONL,
renders to Markdown, and generates documentation via local Ollama or
user-edited prompt templates. Configuration in TOML, fish-shell integration.

See CLAUDE.md for full architecture and design constraints.

Storage layout (XDG):
  $XDG_DATA_HOME/logbook/        (default: ~/.local/share/logbook/)
    active                — active session name (absent = off)
    last                  — last active session name (for `logbook on`)
    pending_tag           — one-shot tag for next cmd event (absent = none)
    sessions/<name>.jsonl    — the log
    sessions/<name>.jsonl.bak — backup written by drop/prune, restored by `restore`

  $XDG_CONFIG_HOME/logbook/      (default: ~/.config/logbook/)
    config.toml           — auto-created skeleton, fully commented (= defaults)
    prompts/<name>.md     — system-prompt templates for `logbook doc`

Event types in JSONL:
  {"ts":"...","type":"init","name":"...","host":"...","user":"..."}
  {"ts":"...","type":"cmd","cmd":"...","cwd":"...","exit":0,"user":"...","host":"...","tag":"..."}
  {"ts":"...","type":"note","text":"..."}
  {"ts":"...","type":"section","title":"..."}

The "tag" field on cmd events is optional, set via `logbook tag <tag>`
before the next command runs.

Line number in the JSONL file = event ID (1-indexed).
"""

import argparse
import json
import os
import re
import shlex
import shutil
import socket
import subprocess
import sys
import time
import tomllib
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path

__version__ = "0.5"

# ---------------------------------------------------------------------------
# Paths

XDG_DATA = Path(os.environ.get("XDG_DATA_HOME", str(Path.home() / ".local" / "share"))) / "logbook"
SESSIONS = XDG_DATA / "sessions"
ACTIVE = XDG_DATA / "active"
LAST = XDG_DATA / "last"
PENDING_TAG = XDG_DATA / "pending_tag"

XDG_CONFIG = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "logbook"
CONFIG_FILE = XDG_CONFIG / "config.toml"
PROMPTS_DIR = XDG_CONFIG / "prompts"

# ---------------------------------------------------------------------------
# Noise filter — commands we silently drop from automatic recording.
# The fish hook does a first pass; this is the python-side safety net.

_NOISE_EXACT = {"cd", "ls", "ll", "la", "pwd", "clear", "exit", "logout", "fg", "bg"}
_NOISE_PREFIXES = ("cd ", "ls ", "logbook ", "logbook\t")

# Valid session names: keep them filesystem-safe and predictable.
_NAME_RE = re.compile(r"^[A-Za-z0-9._-]+$")

# Tags are a bit more permissive — colon is useful for namespacing (e.g. bug:42).
_TAG_RE = re.compile(r"^[A-Za-z0-9._:-]{1,64}$")

# Last-resort Fallback für den System-Prompt. Wird beim ersten `logbook doc`
# nach $XDG_CONFIG_HOME/logbook/prompts/setup-doc.md geschrieben — danach
# editiert der User die Datei. Diese Konstante zieht nur, wenn die Datei
# weder im Setup angelegt noch vom User aufrufbar ist (sollte nicht passieren).
DOC_SYSTEM_PROMPT = """\
Du bist ein technischer Dokumentar. Erstelle aus dem folgenden
Installations-Logbuch eine reproduzierbare Schritt-für-Schritt-Dokumentation
in Markdown.

Regeln:
- Verwende die `## Section`-Überschriften aus dem Log als Hauptgliederung
- Erkläre vor jedem Codeblock in 1-2 Sätzen WAS und WARUM
- Befehle wörtlich beibehalten, nicht "verschönern"
- Fehlgeschlagene Befehle nicht weglassen: kurz als gescheiterter Versuch
  erwähnen; folgt ein erfolgreicher Retry, diesen als kanonisch markieren
- Ton: nüchtern, knapp, Sysadmin-Niveau, kein Marketing
- Sprache: Deutsch
- Nichts erfinden — nur was im Log steht oder unmittelbar logisch folgt
"""

