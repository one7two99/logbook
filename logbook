# ---------------------------------------------------------------------------
# Config loading (cached, lazy, never crashes)

_CONFIG_CACHE: dict | None = None


def load_config() -> dict:
    """Lazy load <XDG_CONFIG>/config.toml via tomllib.

    Fehlende Datei → {}. Kaputtes TOML → stderr-Warning + {}. Caller darf
    sich auf Defaults verlassen, also kein Crash; Resolution-Order
    (CLI > Config > Default) übernimmt config_get."""
    global _CONFIG_CACHE
    if _CONFIG_CACHE is not None:
        return _CONFIG_CACHE
    if not CONFIG_FILE.exists():
        _CONFIG_CACHE = {}
        return _CONFIG_CACHE
    try:
        with CONFIG_FILE.open("rb") as f:
            _CONFIG_CACHE = tomllib.load(f)
    except tomllib.TOMLDecodeError as e:
        print(f"warn: {CONFIG_FILE} ist kaputt ({e}) — verwende Defaults", file=sys.stderr)
        _CONFIG_CACHE = {}
    except OSError as e:
        print(f"warn: {CONFIG_FILE} nicht lesbar ({e}) — verwende Defaults", file=sys.stderr)
        _CONFIG_CACHE = {}
    return _CONFIG_CACHE


def config_get(section: str, key: str, default):
    """Lookup mit Fallback. Wird in argparse-defaults aufgerufen, sodass
    CLI > Config > Hardcode-Default automatisch greift."""
    sec = load_config().get(section)
    if not isinstance(sec, dict):
        return default
    return sec.get(key, default)


def ensure_config_files() -> None:
    """First-run Setup: legt config.toml + prompts/setup-doc.md an, falls
    sie fehlen. Idempotent — niemals etwas überschreiben. Wird lazy beim
    ersten `logbook doc` aufgerufen."""
    XDG_CONFIG.mkdir(parents=True, exist_ok=True)
    if not CONFIG_FILE.exists():
        CONFIG_FILE.write_text(DEFAULT_CONFIG_TOML, encoding="utf-8")
    PROMPTS_DIR.mkdir(parents=True, exist_ok=True)
    setup = PROMPTS_DIR / "setup-doc.md"
    if not setup.exists():
        setup.write_text(DOC_SYSTEM_PROMPT, encoding="utf-8")


def load_prompt(name: str) -> str | None:
    """Lese prompts/<name>.md.

    Returns:
      - File content, falls vorhanden
      - DOC_SYSTEM_PROMPT als Last-Resort-Fallback nur für den well-known
        'setup-doc'-Namen (defensiv; sollte nach ensure_config_files nicht
        nötig sein)
      - None für unbekannte Namen — Caller druckt eine Listing-Fehler-Meldung
    """
    p = PROMPTS_DIR / f"{name}.md"
    if p.exists():
        try:
            return p.read_text(encoding="utf-8")
        except OSError as e:
            print(f"warn: {p} nicht lesbar ({e})", file=sys.stderr)
            return None
    if name == "setup-doc":
        return DOC_SYSTEM_PROMPT
    return None


# ---------------------------------------------------------------------------
# Helpers

def now_iso() -> str:
    """ISO 8601 with local timezone, second precision."""
    return datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")


def ensure_dirs() -> None:
    SESSIONS.mkdir(parents=True, exist_ok=True)


def session_path(name: str) -> Path:
    return SESSIONS / f"{name}.jsonl"


def valid_name(name: str) -> bool:
    return bool(_NAME_RE.match(name)) and not name.startswith(".")


def get_active() -> str | None:
    if ACTIVE.exists():
        s = ACTIVE.read_text().strip()
        return s or None
    return None


def set_active(name: str) -> None:
    ACTIVE.parent.mkdir(parents=True, exist_ok=True)
    ACTIVE.write_text(name)
    LAST.write_text(name)


def clear_active() -> None:
    if ACTIVE.exists():
        ACTIVE.unlink()


def get_pending_tag() -> str | None:
    if not PENDING_TAG.exists():
        return None
    try:
        first = PENDING_TAG.read_text(encoding="utf-8").strip().splitlines()
        return first[0] if first and first[0] else None
    except OSError:
        return None


def clear_pending_tag() -> None:
    if PENDING_TAG.exists():
        PENDING_TAG.unlink()


def append_event(name: str, ev: dict) -> None:
    p = session_path(name)
    p.parent.mkdir(parents=True, exist_ok=True)
    # O_APPEND + single write < PIPE_BUF (4096) is atomic on POSIX.
    line = json.dumps(ev, ensure_ascii=False, separators=(",", ":")) + "\n"
    with p.open("a", encoding="utf-8") as f:
        f.write(line)


def is_noise(cmd: str) -> bool:
    c = cmd.strip()
    if not c:
        return True
    if c in _NOISE_EXACT:
        return True
    for pfx in _NOISE_PREFIXES:
        if c.startswith(pfx):
            return True
    # Config-Erweiterung: trailing space = prefix-match, sonst exact.
    # Beispiel: ["htop", "tmux "] → "htop" exakt, "tmux ..." per Prefix.
    extra = config_get("filter", "extra_noise", []) or []
    for entry in extra:
        if not isinstance(entry, str) or not entry:
            continue
        if entry.endswith(" "):
            if c.startswith(entry):
                return True
        else:
            if c == entry:
                return True
    return False


def load_events(name: str) -> list[dict] | None:
    p = session_path(name)
    if not p.exists():
        print(f"session not found: {name}", file=sys.stderr)
        return None
    events: list[dict] = []
    with p.open(encoding="utf-8") as f:
        for i, raw in enumerate(f, start=1):
            line = raw.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError as e:
                print(f"warn: {p.name}:{i} invalid json: {e}", file=sys.stderr)
                continue
            ev["_line"] = i
            events.append(ev)
    return events


def host() -> str:
    return socket.gethostname()


def user() -> str:
    return os.environ.get("USER") or os.environ.get("LOGNAME") or "unknown"


# ---------------------------------------------------------------------------
# Subcommands

def cmd_init(args) -> int:
    if not valid_name(args.name):
        print(f"invalid session name: {args.name!r} (allowed: A-Z a-z 0-9 . _ -)", file=sys.stderr)
        return 2
    ensure_dirs()
    p = session_path(args.name)
    if p.exists() and not args.force:
        print(f"session already exists: {args.name} (use --force to overwrite)", file=sys.stderr)
        return 1
    if args.force and p.exists():
        p.unlink()
    p.touch()
    append_event(args.name, {
        "ts": now_iso(),
        "type": "init",
        "name": args.name,
        "host": host(),
        "user": user(),
    })
    set_active(args.name)
    print(f"session initialized and active: {args.name}")
    return 0


def cmd_on(args) -> int:
    if not LAST.exists():
        print("no previous session — use `logbook init <name>` first", file=sys.stderr)
        return 1
    name = LAST.read_text().strip()
    if not name or not session_path(name).exists():
        print(f"last session not found on disk: {name!r}", file=sys.stderr)
        return 1
    set_active(name)
    print(f"logging on: {name}")
    return 0


def cmd_off(args) -> int:
    a = get_active()
    if a:
        clear_active()
        print(f"logging off (was: {a})")
    else:
        print("logging already off")
    return 0


def cmd_status(args) -> int:
    a = get_active()
    pt = get_pending_tag()
    if not a:
        print("inactive")
        if pt:
            print(f"pending tag: {pt}  (no active session to attach to)")
        return 0
    p = session_path(a)
    if not p.exists():
        print(f"active session {a!r} but file missing — running `logbook off` is recommended", file=sys.stderr)
        return 1
    n = sum(1 for line in p.open(encoding="utf-8") if line.strip())
    print(f"active: {a}  ({n} events)  → {p}")
    if pt:
        print(f"pending tag: {pt}")
    return 0


def cmd_note(args) -> int:
    a = get_active()
    if not a:
        print("no active session", file=sys.stderr)
        return 1
    append_event(a, {"ts": now_iso(), "type": "note", "text": args.text})
    return 0


def cmd_section(args) -> int:
    a = get_active()
    if not a:
        print("no active session", file=sys.stderr)
        return 1
    append_event(a, {"ts": now_iso(), "type": "section", "title": args.title})
    return 0


def cmd_tag(args) -> int:
    if args.clear:
        prev = get_pending_tag()
        clear_pending_tag()
        if prev:
            print(f"pending tag cleared (was: {prev})")
        else:
            print("no pending tag")
        return 0
    if args.tag is None:
        cur = get_pending_tag()
        print(f"pending tag: {cur}" if cur else "no pending tag")
        return 0
    tag = args.tag.strip()
    if not _TAG_RE.match(tag):
        print(f"invalid tag: {args.tag!r} (allowed: A-Z a-z 0-9 . _ - :, 1-64 chars)", file=sys.stderr)
        return 2
    PENDING_TAG.parent.mkdir(parents=True, exist_ok=True)
    prev = get_pending_tag()
    PENDING_TAG.write_text(tag + "\n", encoding="utf-8")
    if prev and prev != tag:
        print(f"pending tag replaced: {prev} → {tag}")
    else:
        print(f"pending tag set: {tag}  (attaches to next recorded command)")
    return 0


def cmd_record(args) -> int:
    """Internal: called by the fish hook for every executed command."""
    a = get_active()
    if not a:
        return 0  # silently no-op — hook is the gate, this is defense in depth
    cmd = " ".join(args.command).strip() if args.command else ""
    if is_noise(cmd):
        return 0
    ev = {
        "ts": now_iso(),
        "type": "cmd",
        "cmd": cmd,
        "cwd": args.cwd or "",
        "exit": args.exit_code,
        "user": user(),
        "host": host(),
    }
    pending = get_pending_tag()
    if pending:
        ev["tag"] = pending
    append_event(a, ev)
    # Consume the pending tag *after* the append succeeded — if appending
    # raised, the tag stays armed for the next attempt rather than getting
    # silently lost.
    if pending:
        clear_pending_tag()
    return 0


def cmd_list(args) -> int:
    if not SESSIONS.exists():
        print("(no sessions yet)")
        return 0
    a = get_active() or ""
    items = sorted(SESSIONS.glob("*.jsonl"))
    if not items:
        print("(no sessions yet)")
        return 0
    for p in items:
        name = p.stem
        try:
            n = sum(1 for line in p.open(encoding="utf-8") if line.strip())
        except OSError:
            n = -1
        marker = "*" if name == a else " "
        print(f"{marker} {name:<32} {n:>5} events  ({p})")
    return 0


def cmd_show(args) -> int:
    name = args.name or get_active()
    if not name:
        print("no session specified and none active", file=sys.stderr)
        return 1
    events = load_events(name)
    if events is None:
        return 1
    for ev in events:
        i = ev.get("_line", "?")
        t = ev.get("type", "?")
        ts = ev.get("ts", "")
        if t == "cmd":
            ex = ev.get("exit", 0)
            mark = "✓" if ex == 0 else f"✗({ex})"
            tag = ev.get("tag", "")
            tag_str = f" [#{tag}]" if tag else ""
            print(f"{i:>4}  {ts}  {mark}{tag_str}  $ {ev.get('cmd','')}")
        elif t == "note":
            print(f"{i:>4}  {ts}      # {ev.get('text','')}")
        elif t == "section":
            print(f"{i:>4}  {ts}      ## {ev.get('title','')}")
        elif t == "init":
            print(f"{i:>4}  {ts}      -- init {ev.get('name','')} on {ev.get('host','')}")
        else:
            print(f"{i:>4}  {ts}      ? {t} {ev}")
    return 0


def parse_id_range(spec: str) -> tuple[int, int] | None:
    """'5' → (5,5), '5-10' → (5,10). None if malformed."""
    s = spec.strip()
    if "-" in s:
        a, _, b = s.partition("-")
        try:
            lo, hi = int(a), int(b)
        except ValueError:
            return None
        if lo < 1 or hi < lo:
            return None
        return (lo, hi)
    try:
        n = int(s)
    except ValueError:
        return None
    if n < 1:
        return None
    return (n, n)


def cmd_drop(args) -> int:
    rng = parse_id_range(args.spec)
    if rng is None:
        print(f"invalid id or range: {args.spec!r} (expected: N or N-M, 1-indexed)", file=sys.stderr)
        return 2
    lo, hi = rng
    name = args.name or get_active()
    if not name:
        print("no session specified and none active", file=sys.stderr)
        return 1
    p = session_path(name)
    if not p.exists():
        print(f"session not found: {name}", file=sys.stderr)
        return 1

    # Line number in the JSONL file = event ID (per CLAUDE.md). Match on
    # file line numbers — that's what `show` displays.
    kept: list[str] = []
    dropped = 0
    with p.open(encoding="utf-8") as f:
        for i, line in enumerate(f, start=1):
            if lo <= i <= hi:
                dropped += 1
            else:
                kept.append(line)

    if dropped == 0:
        print(f"no lines in range {lo}-{hi} (file has {len(kept)} lines)", file=sys.stderr)
        return 1

    # Backup last-good state, then write filtered events to temp file and
    # atomically rename. Don't edit in place — kill mid-write must leave
    # either the old or the new file intact.
    bak = p.with_suffix(p.suffix + ".bak")
    shutil.copy2(p, bak)
    tmp = p.with_suffix(p.suffix + ".tmp")
    with tmp.open("w", encoding="utf-8") as f:
        f.writelines(kept)
    tmp.replace(p)

    rng_str = f"{lo}" if lo == hi else f"{lo}-{hi}"
    print(f"dropped {dropped} line(s) {rng_str} from {name}  (backup: {bak.name})")
    return 0


def cmd_prune(args) -> int:
    if not args.failed and not args.noise:
        print("specify --failed and/or --noise", file=sys.stderr)
        return 2
    name = args.name or get_active()
    if not name:
        print("no session specified and none active", file=sys.stderr)
        return 1
    p = session_path(name)
    if not p.exists():
        print(f"session not found: {name}", file=sys.stderr)
        return 1

    kept: list[str] = []
    pruned_failed = 0
    pruned_noise = 0
    with p.open(encoding="utf-8") as f:
        for raw in f:
            line = raw.strip()
            if not line:
                kept.append(raw)
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError:
                # Unparseable lines stay — user might want to fix them by hand.
                kept.append(raw)
                continue
            if ev.get("type") == "cmd":
                if args.failed and ev.get("exit", 0) != 0:
                    pruned_failed += 1
                    continue
                if args.noise and is_noise(ev.get("cmd", "")):
                    pruned_noise += 1
                    continue
            kept.append(raw)

    total = pruned_failed + pruned_noise
    if total == 0:
        print(f"nothing to prune in {name}")
        return 0

    bak = p.with_suffix(p.suffix + ".bak")
    shutil.copy2(p, bak)
    tmp = p.with_suffix(p.suffix + ".tmp")
    with tmp.open("w", encoding="utf-8") as f:
        f.writelines(kept)
    tmp.replace(p)

    parts = []
    if args.failed:
        parts.append(f"{pruned_failed} failed")
    if args.noise:
        parts.append(f"{pruned_noise} noise")
    print(f"pruned {total} ({', '.join(parts)}) from {name}  (backup: {bak.name})")
    return 0


def cmd_restore(args) -> int:
    name = args.name or get_active()
    if not name:
        print("no session specified and none active", file=sys.stderr)
        return 1
    p = session_path(name)
    bak = p.with_suffix(p.suffix + ".bak")
    if not bak.exists():
        print(f"no backup found for {name}: {bak.name}", file=sys.stderr)
        return 1
    # Atomic rename — undoes the most recent drop/prune. If the .jsonl is
    # missing entirely (e.g. user nuked it), restore is even more useful.
    bak.replace(p)
    print(f"restored {name} from {bak.name}")
    return 0


def cmd_edit(args) -> int:
    name = args.name or get_active()
    if not name:
        print("no session specified and none active", file=sys.stderr)
        return 1
    p = session_path(name)
    if not p.exists():
        print(f"session not found: {name}", file=sys.stderr)
        return 1
    # VISUAL bevorzugt (full-screen editor), dann EDITOR, dann vi — POSIX-Konvention.
    editor = os.environ.get("VISUAL") or os.environ.get("EDITOR") or "vi"
    # shlex split so VISUAL="nvim -u NONE" or "code --wait" works.
    argv = shlex.split(editor) + [str(p)]
    try:
        return subprocess.run(argv).returncode
    except FileNotFoundError:
        print(f"editor not found: {argv[0]}", file=sys.stderr)
        return 1


def render_markdown(name: str, events: list[dict]) -> str:
    """Render events to the Markdown form shown by `logbook render`.

    Pure function — keine I/O — damit `logbook doc` denselben Text als
    User-Prompt an Ollama schicken kann. Output ist byte-identisch zur
    vormaligen Inline-Implementierung in cmd_render.
    """
    init_ev = next((e for e in events if e.get("type") == "init"), None)
    cmd_events = [e for e in events if e.get("type") == "cmd"]
    failed = [e for e in cmd_events if e.get("exit", 0) != 0]
    first_ts = events[0].get("ts", "") if events else ""
    last_ts = events[-1].get("ts", "") if events else ""
    h = init_ev.get("host", "?") if init_ev else "?"
    u = init_ev.get("user", "?") if init_ev else "?"

    out: list[str] = []
    out.append(f"# logbook: {name}")
    out.append("")
    out.append(f"- **Host:** {h}")
    out.append(f"- **User:** {u}")
    out.append(f"- **Beginn:** {first_ts}")
    out.append(f"- **Ende:** {last_ts}")
    out.append(f"- **Befehle:** {len(cmd_events)} (davon {len(failed)} fehlgeschlagen)")
    out.append("")

    for ev in events:
        t = ev.get("type")
        if t == "section":
            out.append("")
            out.append(f"## {ev.get('title','')}")
            out.append("")
        elif t == "note":
            out.append(f"> {ev.get('text','')}")
            out.append("")
        elif t == "cmd":
            cmd = ev.get("cmd", "")
            ex = ev.get("exit", 0)
            cwd = ev.get("cwd", "")
            ts = ev.get("ts", "")
            tag = ev.get("tag", "")
            meta_parts = [f"ts: {ts}", f"cwd: {cwd}"]
            if tag:
                meta_parts.append(f"tag: {tag}")
            if ex != 0:
                meta_parts.append(f"exit: {ex}")
            out.append("```bash")
            out.append(f"# {' | '.join(meta_parts)}")
            out.append(cmd)
            out.append("```")
            out.append("")

    return "\n".join(out) + "\n"


def cmd_render(args) -> int:
    name = args.name or get_active()
    if not name:
        print("no session specified and none active", file=sys.stderr)
        return 1
    events = load_events(name)
    if events is None:
        return 1
    sys.stdout.write(render_markdown(name, events))
    return 0


def ollama_generate(prompt: str, model: str, system: str, endpoint: str, temperature: float):
    """POSTs to <endpoint>/api/generate with stream=true. Yields response chunks.

    NDJSON-Response: pro Zeile ein JSON-Objekt mit "response"-Feld; die
    letzte Zeile trägt "done": true. urllib's Response ist iterable über
    Zeilen — keine Buffer-Akrobatik nötig.

    `think: false`: bei Reasoning-Modellen (qwen3, deepseek-r1, ...) wandert
    sonst alles in ein "thinking"-Feld und "response" bleibt leer — Caller
    würde nichts sehen. Für die Docs-Anwendung wollen wir die Antwort, nicht
    das Reasoning. Auf Nicht-Thinking-Modellen wird das Flag ignoriert.
    """
    payload = {
        "model": model,
        "system": system,
        "prompt": prompt,
        "stream": True,
        "think": bool(config_get("llm", "think", False)),
        "options": {
            "temperature": temperature,
            "seed": int(config_get("llm", "seed", 42)),
        },
    }
    req = urllib.request.Request(
        f"{endpoint.rstrip('/')}/api/generate",
        data=json.dumps(payload, ensure_ascii=False).encode("utf-8"),
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req) as resp:
        for raw in resp:
            line = raw.strip()
            if not line:
                continue
            try:
                chunk = json.loads(line)
            except json.JSONDecodeError:
                continue
            yield chunk.get("response", "")
            if chunk.get("done"):
                return


def cmd_doc(args) -> int:
    # First-run setup: idempotent skeleton config + default prompt template.
    # Bewusst auch bei --prompt-only, damit der erste Aufruf in beiden Modi
    # dieselben Files anlegt.
    ensure_config_files()

    # Save-Ziel auflösen: --save-to (explizit) > --save (config docs_dir) > nichts.
    if args.save_to:
        save_dir: Path | None = Path(args.save_to).expanduser()
    elif args.save:
        docs_dir = config_get("output", "docs_dir", None)
        if not docs_dir:
            print("--save needs [output].docs_dir in config.toml", file=sys.stderr)
            return 2
        save_dir = Path(str(docs_dir)).expanduser()
    else:
        save_dir = None

    if args.commit and save_dir is None:
        print("--commit requires --save or --save-to", file=sys.stderr)
        return 2

    name = args.name or get_active()
    if not name:
        print("no session specified and none active", file=sys.stderr)
        return 1
    events = load_events(name)
    if events is None:
        return 1

    # System-Prompt aus Template-Datei. Fehlende Datei → klare Fehlermeldung
    # mit Listing aller vorhandenen Templates.
    system = load_prompt(args.prompt)
    if system is None:
        avail = sorted(p.stem for p in PROMPTS_DIR.glob("*.md")) if PROMPTS_DIR.exists() else []
        if avail:
            print(
                f"prompt nicht gefunden: {args.prompt!r}\nverfügbar: {', '.join(avail)}",
                file=sys.stderr,
            )
        else:
            print(
                f"prompt nicht gefunden: {args.prompt!r} (keine Templates in {PROMPTS_DIR})",
                file=sys.stderr,
            )
        return 1

    user_prompt = render_markdown(name, events)

    if args.prompt_only:
        sys.stdout.write("=== SYSTEM ===\n")
        sys.stdout.write(system)
        if not system.endswith("\n"):
            sys.stdout.write("\n")
        sys.stdout.write("\n=== USER ===\n")
        sys.stdout.write(user_prompt)
        return 0

    collected: list[str] = []
    got_any = False
    try:
        for chunk in ollama_generate(
            prompt=user_prompt,
            model=args.model,
            system=system,
            endpoint=args.endpoint,
            temperature=args.temperature,
        ):
            if chunk:
                got_any = True
            sys.stdout.write(chunk)
            sys.stdout.flush()
            if save_dir is not None:
                collected.append(chunk)
    except urllib.error.HTTPError as e:
        body = ""
        try:
            body = e.read().decode("utf-8", errors="replace")
        except Exception:
            pass
        if e.code == 404 or "model" in body.lower():
            print(
                f"\nModell {args.model!r} nicht installiert. "
                f"Pull: `ollama pull {args.model}`",
                file=sys.stderr,
            )
            return 1
        print(f"\nOllama-Fehler: HTTP {e.code} — {body[:200]}", file=sys.stderr)
        return 1
    except urllib.error.URLError as e:
        if isinstance(e.reason, ConnectionRefusedError):
            print(
                f"\nollama nicht erreichbar unter {args.endpoint}. "
                f"Läuft `ollama serve`? Status: `systemctl --user status ollama`",
                file=sys.stderr,
            )
            return 1
        print(f"\nVerbindungsfehler: {e.reason}", file=sys.stderr)
        return 1

    sys.stdout.write("\n")

    if not got_any:
        print(
            "warn: Modell hat keinen sichtbaren Output erzeugt — vermutlich "
            "ein Thinking-Modell, das `think: false` ignoriert. Versuche ein "
            "Nicht-Reasoning-Modell (z.B. llama3.1:8b, qwen2.5:7b) oder eine "
            "neuere Ollama-Version.",
            file=sys.stderr,
        )

    if save_dir is not None:
        save_dir.mkdir(parents=True, exist_ok=True)
        out_path = save_dir / f"{name}.md"
        out_path.write_text("".join(collected) + "\n", encoding="utf-8")
        print(f"gespeichert: {out_path}", file=sys.stderr)

        should_commit = args.commit or bool(config_get("output", "auto_commit", False))
        if should_commit:
            try:
                r = subprocess.run(
                    ["git", "-C", str(save_dir), "rev-parse", "--show-toplevel"],
                    capture_output=True, text=True, timeout=5,
                )
            except FileNotFoundError:
                print("warn: `git` nicht im PATH — commit übersprungen", file=sys.stderr)
                return 0
            except subprocess.TimeoutExpired:
                print("warn: git rev-parse Timeout — commit übersprungen", file=sys.stderr)
                return 0
            if r.returncode != 0:
                print(
                    f"warn: {save_dir} ist kein git-Repo — commit übersprungen, "
                    f"Datei trotzdem gespeichert",
                    file=sys.stderr,
                )
                return 0
            repo_root = r.stdout.strip()
            subprocess.run(["git", "-C", repo_root, "add", "-A"], check=False)
            subprocess.run(
                ["git", "-C", repo_root, "commit", "-m", f"logbook doc: {name}"],
                check=False,
            )

    return 0


# ---------------------------------------------------------------------------
# `logbook help [topic]` — Closure-Factory: cmd_help braucht Zugriff auf
# parser + subparsers, ohne dass wir sie als globale Variablen herumschleppen.

def make_cmd_help(parser: argparse.ArgumentParser, sub):
    def cmd_help(args) -> int:
        if not args.topic:
            parser.print_help()
            return 0
        if args.topic in sub.choices:
            sub.choices[args.topic].print_help()
            return 0
        avail = sorted(name for name in sub.choices.keys() if not name.startswith("_"))
        print(
            f"unknown subcommand: {args.topic!r}\n"
            f"available: {', '.join(avail)}",
            file=sys.stderr,
        )
        return 1
    return cmd_help


# ---------------------------------------------------------------------------
# `logbook config show|edit|path|reset`

def _fmt_toml_value(v) -> str:
    """TOML-ähnliche Wertedarstellung für `config show`."""
    if v is None:
        return "(not set)"
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, str):
        return f'"{v}"'
    if isinstance(v, list):
        return "[" + ", ".join(_fmt_toml_value(x) for x in v) + "]"
    return str(v)


def cmd_config_show(args) -> int:
    cfg = load_config()
    cfg_exists = CONFIG_FILE.exists()
    longest = max(len(k) for _, keys in CONFIG_SCHEMA for k, _ in keys)
    val_col = max(
        len(_fmt_toml_value(cfg.get(sec, {}).get(k, default)))
        for sec, keys in CONFIG_SCHEMA
        for k, default in keys
    )

    for section, keys in CONFIG_SCHEMA:
        print(f"[{section}]")
        sec_dict = cfg.get(section) if isinstance(cfg.get(section), dict) else {}
        for key, default in keys:
            if key in sec_dict:
                value = sec_dict[key]
                source = "[config.toml]"
            else:
                value = default
                source = "[default]"
            v = _fmt_toml_value(value)
            print(f"  {key:<{longest}}  = {v:<{val_col}}    {source}")
        print()

    print(f"config.toml: {CONFIG_FILE}{'' if cfg_exists else '  (nicht angelegt)'}")
    if PROMPTS_DIR.exists():
        tpls = sorted(p.stem for p in PROMPTS_DIR.glob("*.md"))
        suffix = f"  ({len(tpls)} template{'s' if len(tpls) != 1 else ''}"
        if tpls:
            suffix += f": {', '.join(tpls)}"
        suffix += ")"
        print(f"prompts:     {PROMPTS_DIR}{suffix}")
    else:
        print(f"prompts:     {PROMPTS_DIR}  (nicht angelegt)")
    if not cfg_exists:
        print()
        print("Hinweis: config.toml existiert noch nicht — `logbook doc` legt sie")
        print("beim ersten Lauf an, oder direkt `logbook config edit`.")
    return 0


def cmd_config_edit(args) -> int:
    # Damit der Editor was zum Editieren findet, vorher idempotent anlegen.
    ensure_config_files()
    editor = os.environ.get("VISUAL") or os.environ.get("EDITOR") or "vi"
    argv = shlex.split(editor) + [str(CONFIG_FILE)]
    try:
        return subprocess.run(argv).returncode
    except FileNotFoundError:
        print(f"editor not found: {argv[0]}", file=sys.stderr)
        return 1


def cmd_config_path(args) -> int:
    print(CONFIG_FILE)
    return 0


def cmd_config_reset(args) -> int:
    if not XDG_CONFIG.exists():
        print(f"{XDG_CONFIG} existiert nicht — nichts zu tun")
        return 0
    if not args.yes:
        if not sys.stdin.isatty():
            print(
                "reset benötigt --yes wenn nicht interaktiv",
                file=sys.stderr,
            )
            return 1
        print(f"löscht {XDG_CONFIG} (Backup wird angelegt). weiter? [y/N] ", end="", flush=True)
        try:
            answer = input().strip().lower()
        except EOFError:
            answer = ""
        if answer not in ("y", "yes", "j", "ja"):
            print("abgebrochen")
            return 0
    ts = datetime.now().strftime("%Y%m%dT%H%M%S")
    backup = XDG_CONFIG.parent / f"logbook.bak.{ts}"
    try:
        # shutil.move = atomarer rename auf demselben Filesystem; falls das
        # Backup-Ziel nicht erstellt werden kann, lieber abbrechen als
        # halbgaren Zustand zu hinterlassen.
        shutil.move(str(XDG_CONFIG), str(backup))
    except OSError as e:
        print(f"backup failed, nichts gelöscht: {e}", file=sys.stderr)
        return 1
    print(f"backup: {backup}")
    print(f"reset:  {XDG_CONFIG} entfernt")
    return 0


