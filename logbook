# `logbook info` — Status-Dashboard

def _ollama_models(endpoint: str, timeout: float = 2.0) -> list[str] | None:
    """GET <endpoint>/api/tags. None bei jedem Fehler (Timeout, refused,
    HTTP-Error, Garbage). Kein Stacktrace, kein Exit != 0."""
    url = f"{endpoint.rstrip('/')}/api/tags"
    try:
        req = urllib.request.Request(url, method="GET")
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            data = json.loads(resp.read().decode("utf-8", errors="replace"))
    except (urllib.error.URLError, OSError, json.JSONDecodeError, TimeoutError):
        return None
    models = data.get("models") if isinstance(data, dict) else None
    if not isinstance(models, list):
        return []
    out: list[str] = []
    for m in models:
        if isinstance(m, dict) and isinstance(m.get("name"), str):
            out.append(m["name"])
    return out


def cmd_info(args) -> int:
    print(f"logbook {__version__}")
    print()

    active = get_active()
    if active:
        ap = session_path(active)
        try:
            n = sum(1 for line in ap.open(encoding="utf-8") if line.strip()) if ap.exists() else 0
        except OSError:
            n = 0
        print(f"Active session:  {active}  ({n} events)")
        print(f"                 {ap}")
    else:
        print("Active session:  (none)")
    print()

    print("Paths:")
    print(f"  data:          {XDG_DATA}")
    print(f"  config:        {XDG_CONFIG}")
    sess_count = len(list(SESSIONS.glob("*.jsonl"))) if SESSIONS.exists() else 0
    print(f"  sessions:      {SESSIONS}  ({sess_count} session{'s' if sess_count != 1 else ''})")
    tpl_count = len(list(PROMPTS_DIR.glob("*.md"))) if PROMPTS_DIR.exists() else 0
    print(f"  prompts:       {PROMPTS_DIR}  ({tpl_count} template{'s' if tpl_count != 1 else ''})")
    print()

    endpoint = str(config_get("llm", "endpoint", "http://localhost:11434"))
    models = _ollama_models(endpoint)
    if models is None:
        print(f"Ollama:          {endpoint}  ✗ nicht erreichbar")
    else:
        print(f"Ollama:          {endpoint}  ✓ erreichbar")
        if models:
            preview = ", ".join(models[:5])
            extra = f" (+{len(models) - 5} weitere)" if len(models) > 5 else ""
            print(f"  Modelle:       {preview}{extra}  ({len(models)} installiert)")
        else:
            print("  Modelle:       (keine installiert)")
    print()

    if CONFIG_FILE.exists():
        print(f"Config:          {CONFIG_FILE}  ✓ existiert")
        print("  Aktive Werte:  `logbook config show`")
    else:
        print(f"Config:          {CONFIG_FILE}  (nicht angelegt)")
    return 0


# ---------------------------------------------------------------------------
# `logbook search <pattern>` — grep über alle Sessions

def _ansi_highlight(s: str, match_re: re.Pattern, on: bool) -> str:
    if not on:
        return s
    return match_re.sub(lambda m: f"\033[1m{m.group(0)}\033[0m", s)


def cmd_search(args) -> int:
    flags = 0 if args.case_sensitive else re.IGNORECASE
    try:
        pat = re.compile(args.pattern, flags)
    except re.error as e:
        print(f"invalid regex: {e}", file=sys.stderr)
        return 2
    if not SESSIONS.exists():
        return 1

    types_wanted = {args.type} if args.type else {"cmd", "note"}
    highlight = sys.stdout.isatty()
    hits = 0
    for sp in sorted(SESSIONS.glob("*.jsonl")):
        name = sp.stem
        try:
            with sp.open(encoding="utf-8") as f:
                for i, raw in enumerate(f, start=1):
                    line = raw.strip()
                    if not line:
                        continue
                    try:
                        ev = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    t = ev.get("type")
                    if t not in types_wanted:
                        continue
                    content = ev.get("cmd") if t == "cmd" else ev.get("text")
                    if not isinstance(content, str):
                        continue
                    if not pat.search(content):
                        continue
                    ts = ev.get("ts", "")
                    out = _ansi_highlight(content, pat, highlight)
                    print(f"{name}:{i}  {ts}  {t:<4}  {out}")
                    hits += 1
        except OSError:
            continue
    return 0 if hits else 1


# ---------------------------------------------------------------------------
# `logbook tail [name]` — Live-Viewer mit Polling (~300ms), stdlib only

TAIL_GREEN = "\033[32m"
TAIL_RED = "\033[31m"
TAIL_YELLOW = "\033[33m"
TAIL_CYAN = "\033[36m"
TAIL_MAGENTA = "\033[35m"
TAIL_BOLD = "\033[1m"
TAIL_DIM = "\033[2m"
TAIL_RESET = "\033[0m"


def _tail_wrap(text: str, *codes: str, on: bool) -> str:
    if not on or not codes:
        return text
    return "".join(codes) + text + TAIL_RESET


def _tail_ts_short(ts: str) -> str:
    """ISO 8601 → HH:MM:SS. Andere Strings: erste 8 Zeichen."""
    if "T" in ts:
        return ts.split("T", 1)[1][:8]
    return ts[:8] if len(ts) >= 8 else ts


def _tail_format_event(ev: dict, color_on: bool) -> str | None:
    """Eine Zeile pro Event für den Live-View.

    Returns None für init/unknown — die werden nicht gestreamt, init
    landet im Banner."""
    t = ev.get("type")
    ts = _tail_ts_short(str(ev.get("ts", "")))
    if t == "cmd":
        ex = ev.get("exit", 0)
        if ex == 0:
            marker = _tail_wrap("✓     ", TAIL_GREEN, on=color_on)
        else:
            mtext = f"✗{ex}"
            pad = max(1, 6 - len(mtext))
            marker = _tail_wrap(mtext + " " * pad, TAIL_RED, on=color_on)
        tag = ev.get("tag")
        tag_prefix = ""
        if isinstance(tag, str) and tag:
            tag_prefix = _tail_wrap(f"#{tag}", TAIL_BOLD, TAIL_MAGENTA, on=color_on) + "  "
        return f"{ts}  {tag_prefix}{marker}$ {ev.get('cmd', '')}"
    if t == "section":
        marker = _tail_wrap("§     ", TAIL_BOLD, TAIL_YELLOW, on=color_on)
        return f"{ts}  {marker}{ev.get('title', '')}"
    if t == "note":
        marker = _tail_wrap(">     ", TAIL_DIM, TAIL_CYAN, on=color_on)
        return f"{ts}  {marker}{ev.get('text', '')}"
    return None


def cmd_tail(args) -> int:
    color_on = (
        sys.stdout.isatty()
        and not args.no_color
        and not os.environ.get("NO_COLOR")
    )

    filt_re = None
    if args.filter:
        try:
            filt_re = re.compile(args.filter)
        except re.error as e:
            print(f"invalid regex: {e}", file=sys.stderr)
            return 2
    type_filter = args.type

    explicit = args.name
    if explicit and not session_path(explicit).exists():
        print(f"session not found: {explicit}", file=sys.stderr)
        return 1

    def _matches(ev: dict) -> bool:
        t = ev.get("type")
        if t not in ("cmd", "note", "section"):
            return False
        if type_filter and t != type_filter:
            return False
        if filt_re:
            if t == "cmd":
                content = ev.get("cmd", "")
            elif t == "note":
                content = ev.get("text", "")
            else:
                content = ev.get("title", "")
            if not isinstance(content, str) or not filt_re.search(content):
                return False
        return True

    def _emit(line: str) -> None:
        print(line, flush=True)

    def _banner(name: str) -> None:
        if not color_on:
            return
        now_str = datetime.now().strftime("%H:%M:%S")
        title = _tail_wrap(f"== session: {name} ==", TAIL_BOLD, on=color_on)
        _emit(f"{title}    started watching at {now_str}")

    def _paused() -> None:
        if color_on:
            _emit(_tail_wrap("⏸ session paused", TAIL_DIM, on=color_on))

    def _no_active_msg() -> None:
        if color_on:
            _emit(_tail_wrap(
                "⏸ no active session — start one with `logbook init <name>`",
                TAIL_DIM,
                on=color_on,
            ))

    def _separator() -> None:
        if color_on:
            _emit(_tail_wrap("---", TAIL_DIM, on=color_on))

    def _read_new(path: Path, offset: int) -> tuple[int, list[dict]]:
        evs: list[dict] = []
        try:
            with path.open("r", encoding="utf-8", errors="replace") as f:
                f.seek(offset)
                for raw in f:
                    line = raw.strip()
                    if not line:
                        continue
                    try:
                        evs.append(json.loads(line))
                    except json.JSONDecodeError:
                        continue
                new_off = f.tell()
        except OSError:
            return offset, []
        return new_off, evs

    def _seek_end(name: str) -> int:
        try:
            return session_path(name).stat().st_size
        except OSError:
            return 0

    # Initiale Resolution. paused trennt "wir folgen sess X aber X ist gerade
    # off" von "wir folgen niemandem" — so kann Resume auf X den alten
    # Offset weiterlesen, statt zu skippen.
    current_session: str | None = explicit or get_active()
    current_offset: int = 0
    paused = False
    missing_warned = False

    if current_session is None:
        _no_active_msg()
    else:
        p = session_path(current_session)
        _banner(current_session)
        if p.exists():
            if args.lines > 0:
                events = load_events(current_session) or []
                matched = [ev for ev in events if _matches(ev)]
                for ev in matched[-args.lines:]:
                    line = _tail_format_event(ev, color_on)
                    if line is not None:
                        _emit(line)
            current_offset = _seek_end(current_session)

    while True:
        time.sleep(0.3)

        # Ziel-Session: bei explicit fix, sonst active-File.
        desired = explicit if explicit else get_active()

        if desired is None:
            # active wurde entfernt — Pause, State behalten für Resume.
            if not paused and current_session is not None:
                _paused()
                paused = True
            continue

        if current_session is None:
            # Erstes Aufleben aus "no active at start": skip to end (kein Replay).
            current_session = desired
            current_offset = _seek_end(desired)
            paused = False
            missing_warned = False
            _banner(desired)
        elif paused and desired == current_session:
            # Resume derselben Session — Offset behalten, neue Events kommen.
            paused = False
        elif desired != current_session:
            # Wechsel auf andere Session: Separator + Skip to End.
            _separator()
            current_session = desired
            current_offset = _seek_end(desired)
            paused = False
            missing_warned = False
            _banner(desired)

        p = session_path(current_session)
        if not p.exists():
            # Race condition bei init oder gelöschte explicit Datei.
            if explicit and not missing_warned:
                print(
                    f"warn: {p} verschwunden — polle weiter, falls sie wiederkommt",
                    file=sys.stderr,
                )
                missing_warned = True
            continue

        try:
            size = p.stat().st_size
        except OSError:
            continue

        if size < current_offset:
            # Truncation (z.B. nach manuellem edit) — von vorne lesen.
            current_offset = 0
        if size > current_offset:
            new_off, evs = _read_new(p, current_offset)
            for ev in evs:
                if _matches(ev):
                    line = _tail_format_event(ev, color_on)
                    if line is not None:
                        _emit(line)
            current_offset = new_off


# ---------------------------------------------------------------------------
# Entry point

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="logbook",
        description="Install-Logbook recorder. Captures CLI commands, notes, and sections to JSONL.",
    )
    p.add_argument(
        "--version", "-V",
        action="version",
        version=f"logbook {__version__}",
    )
    # required=False: bares `logbook` druckt Hilfe (siehe main).
    sub = p.add_subparsers(dest="cmd", metavar="<command>")

    s = sub.add_parser("init", help="start a new session and activate it")
    s.add_argument("name", help="session name (A-Z a-z 0-9 . _ -)")
    s.add_argument("--force", action="store_true", help="overwrite existing session")
    s.set_defaults(func=cmd_init)

    s = sub.add_parser("on", help="resume logging into the last session")
    s.set_defaults(func=cmd_on)

    s = sub.add_parser("off", help="pause logging")
    s.set_defaults(func=cmd_off)

    s = sub.add_parser("status", help="show current state")
    s.set_defaults(func=cmd_status)

    s = sub.add_parser("note", help="add a prose note to the active session")
    s.add_argument("text")
    s.set_defaults(func=cmd_note)

    s = sub.add_parser("section", help="start a new section (H2 in render)")
    s.add_argument("title")
    s.set_defaults(func=cmd_section)

    s = sub.add_parser("tag", help="arm a tag to attach to the next recorded command")
    s.add_argument("tag", nargs="?", help="tag value (omit to show pending, use --clear to remove)")
    s.add_argument("--clear", action="store_true", help="clear pending tag")
    s.set_defaults(func=cmd_tag)

    s = sub.add_parser("list", help="list all sessions")
    s.set_defaults(func=cmd_list)

    s = sub.add_parser("show", help="dump session events as plain text")
    s.add_argument("name", nargs="?", help="session name (default: active)")
    s.set_defaults(func=cmd_show)

    s = sub.add_parser("edit", help="open the session JSONL in $EDITOR (fallback vi)")
    s.add_argument("name", nargs="?", help="session name (default: active)")
    s.set_defaults(func=cmd_edit)

    s = sub.add_parser("drop", help="delete event(s) by line id (single N or range N-M)")
    s.add_argument("spec", help="event id (e.g. 5) or range (e.g. 5-10), 1-indexed")
    s.add_argument("name", nargs="?", help="session name (default: active)")
    s.set_defaults(func=cmd_drop)

    s = sub.add_parser("prune", help="bulk remove events: --failed and/or --noise")
    s.add_argument("--failed", action="store_true", help="remove type:cmd with exit != 0")
    s.add_argument("--noise", action="store_true", help="apply noise filter retroactively to type:cmd events")
    s.add_argument("name", nargs="?", help="session name (default: active)")
    s.set_defaults(func=cmd_prune)

    s = sub.add_parser("restore", help="restore the .bak backup created by drop/prune")
    s.add_argument("name", nargs="?", help="session name (default: active)")
    s.set_defaults(func=cmd_restore)

    s = sub.add_parser("render", help="render session as Markdown on stdout")
    s.add_argument("name", nargs="?", help="session name (default: active)")
    s.set_defaults(func=cmd_render)

    s = sub.add_parser("doc", help="LLM-rendered Doku via Ollama (streamed)")
    s.add_argument("name", nargs="?", help="session name (default: active)")
    s.add_argument(
        "--model",
        default=config_get("llm", "model", "qwen3.6:35b-a3b"),
        help="Ollama-Modell (default: aus config.toml oder qwen3.6:35b-a3b)",
    )
    s.add_argument(
        "--endpoint",
        default=config_get("llm", "endpoint", "http://localhost:11434"),
        help="Ollama-Endpoint (default: aus config.toml oder http://localhost:11434)",
    )
    s.add_argument(
        "--temperature",
        type=float,
        default=float(config_get("llm", "temperature", 0.2)),
        help="sampling temperature (default: aus config.toml oder 0.2)",
    )
    s.add_argument(
        "--prompt",
        default=str(config_get("llm", "default_prompt", "setup-doc")),
        metavar="NAME",
        help="Prompt-Template <XDG_CONFIG>/prompts/<NAME>.md (default: setup-doc)",
    )
    s.add_argument("--save-to", metavar="DIR", help="zusätzlich nach <DIR>/<session>.md schreiben")
    s.add_argument(
        "--save",
        action="store_true",
        help="zusätzlich nach [output].docs_dir aus config.toml schreiben",
    )
    s.add_argument("--commit", action="store_true", help="(nur mit --save/--save-to) git add -A && git commit im Ziel-Repo")
    s.add_argument("--prompt-only", action="store_true", help="nur System+User-Prompt drucken, kein LLM-Call")
    s.set_defaults(func=cmd_doc)

    s = sub.add_parser("tail", help="live-follow active or named session")
    s.add_argument("name", nargs="?", help="session name (default: follow active)")
    s.add_argument(
        "--lines", "-n",
        type=int, default=0, metavar="N",
        help="show last N events before follow (default: 0)",
    )
    s.add_argument("--filter", metavar="REGEX", help="match cmd/note/section content")
    s.add_argument(
        "--type",
        choices=["cmd", "note", "section"],
        help="restrict to a single event type",
    )
    s.add_argument("--no-color", action="store_true", help="force plain output even on TTY")
    s.set_defaults(func=cmd_tail)

    s = sub.add_parser("info", help="status dashboard (paths, ollama, config)")
    s.set_defaults(func=cmd_info)

    s = sub.add_parser("search", help="grep über cmd+note Felder aller Sessions")
    s.add_argument("pattern", help="regex (default case-insensitive)")
    s.add_argument("--case-sensitive", "-c", action="store_true", help="case-sensitive match")
    s.add_argument("--type", choices=["cmd", "note"], help="nur diesen Event-Typ durchsuchen")
    s.set_defaults(func=cmd_search)

    s = sub.add_parser("config", help="manage logbook configuration")
    csub = s.add_subparsers(dest="config_cmd", required=True, metavar="<action>")
    cs = csub.add_parser("show", help="effective config dumpen, mit Quelle pro Wert")
    cs.set_defaults(func=cmd_config_show)
    ce = csub.add_parser("edit", help="config.toml im $EDITOR öffnen")
    ce.set_defaults(func=cmd_config_edit)
    cp = csub.add_parser("path", help="absoluten Pfad zur config.toml drucken")
    cp.set_defaults(func=cmd_config_path)
    cr = csub.add_parser("reset", help="config.toml + prompts/ löschen (mit Backup)")
    cr.add_argument("-y", "--yes", action="store_true", help="ohne Rückfrage")
    cr.set_defaults(func=cmd_config_reset)

    s = sub.add_parser("help", help="show help (optional: for a specific subcommand)")
    s.add_argument("topic", nargs="?", help="subcommand name")
    s.set_defaults(func=make_cmd_help(p, sub))

    # Internal — called by the fish hook
    s = sub.add_parser("_record", help=argparse.SUPPRESS)
    s.add_argument("--exit-code", type=int, default=0)
    s.add_argument("--cwd", default="")
    s.add_argument("command", nargs="+")
    s.set_defaults(func=cmd_record)

    return p


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    if not args.cmd:
        parser.print_help()
        return 0
    return args.func(args) or 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
    except BrokenPipeError:
        sys.exit(0)
